        "configurationVersion": 0,
        "configuration": {
          "scriptLang": "JS",
          "jsScript": "if (typeof msg.temperature !== 'undefined') {\n    var dioValue = (parseFloat(msg.temperature) >= 25) ? 1 : 0;\n    return {msg: {method: 'setDIO16', params: {value: dioValue}}, metadata: metadata, msgType: 'RPC_CALL_FROM_SERVER_TO_DEVICE'};\n}\nreturn null;"
        },
        "additionalInfo": {
          "layoutX": 10,
