          "scriptLang": "JS",
          "jsScript": "\nvar newMsg = JSON.parse(JSON.stringify(msg));\nif (typeof newMsg.temperature !== 'undefined') {\n    newMsg.DIO16 = (parseFloat(newMsg.temperature) >= 25) ? 1 : 0;\n}\nreturn {msg: newMsg, metadata: metadata, msgType: 'POST_TELEMETRY_REQUEST'};\n"
